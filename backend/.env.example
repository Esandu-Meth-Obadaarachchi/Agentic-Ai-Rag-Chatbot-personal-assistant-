# Copy to .env and fill in. Reuse the same keys as the frontend (second-brain/.env.local).
# .env is gitignored — never commit real keys.

APP_ENV=dev

# --- Anthropic: generation + agent reasoning ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_FAST_MODEL=claude-haiku-4-5

# --- Voyage: embeddings + cross-encoder reranking ---
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3.5
VOYAGE_RERANK_MODEL=rerank-2.5
EMBED_DIM=1024

# --- Pinecone: vector store (one namespace per project) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=second-brain

# --- Firebase Admin: auth (verify ID tokens) + Firestore ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Keep the literal \n escapes from the service-account JSON; the app un-escapes them.
FIREBASE_ADMIN_PRIVATE_KEY=

# --- LangSmith: optional tracing (no-op unless enabled) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-rag-aws

# --- CORS: comma-separated frontend origins allowed to call the API ---
CORS_ORIGINS=http://localhost:3000
